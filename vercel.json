{
  "redirects": [
    {
      "source": "/:path((?!\\.well-known).*)",
      "has": [
        {
          "type": "host",
          "value": "geonautsguide.com"
        }
      ],
      "destination": "https://www.geonautsguide.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
